#!/usr/bin/env bash

TEMP="$(sensors | grep 'temp1' | grep --only-match '[[:digit:]]\{1,3\}\.[[:digit:]].C[^)]')"

BATTERY="BAT $(cat /sys/class/power_supply/BAT0/capacity)%"

AUDIO_DATA="$(amixer sget Master)"
VOLUME="$(echo "$AUDIO_DATA" | grep --only-match '[[:digit:]]\{1,3\}%')"
IS_MUTED() {
  [[ "$(echo "$AUDIO_DATA" | grep --only-match '\[off\]')" != '' ]]
}

if IS_MUTED; then
  AUDIO_LABEL='VOL MUTED'
else
  AUDIO_LABEL="VOL $VOLUME"
fi

TIME="$(date '+%a %l:%M %p')"

LABEL="$TIME  $BATTERY  $AUDIO_LABEL  $TEMP"

xsetroot -name "$LABEL"
